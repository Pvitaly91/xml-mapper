APP_NAME="xml-mapper.loc"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://xml-mapper.loc
APP_TIMEZONE=Europe/Kyiv
FEED_MEDIATOR_ENV_CLASS=local
FEED_MEDIATOR_ENV_LABEL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12


LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xml_mapper_loc
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=900

FEED_MEDIATOR_QUEUE_IMPORTS=imports
FEED_MEDIATOR_QUEUE_NORMALIZATION=normalization
FEED_MEDIATOR_QUEUE_FEEDS=feeds
FEED_MEDIATOR_QUEUE_DICTIONARIES=dictionaries

FEED_MEDIATOR_LOCK_PREFIX=feed-mediator
FEED_MEDIATOR_DISPATCH_LOCK_TTL_SECONDS=1800
FEED_MEDIATOR_SOURCE_SYNC_LOCK_TTL_SECONDS=1800
FEED_MEDIATOR_FEED_BUILD_LOCK_TTL_SECONDS=1800
FEED_MEDIATOR_FEED_PUBLISH_LOCK_TTL_SECONDS=900
FEED_MEDIATOR_DICTIONARY_IMPORT_LOCK_TTL_SECONDS=1800

FEED_MEDIATOR_HEARTBEAT_STALE_AFTER_SECONDS=180
FEED_MEDIATOR_FAILED_JOBS_DEGRADED_THRESHOLD=1
FEED_MEDIATOR_KASTA_DICTIONARY_SAMPLE_PATH=
FEED_MEDIATOR_KASTA_DICTIONARY_STORAGE_DIRECTORY=imports/dictionaries
FEED_MEDIATOR_STORAGE_DISK=local
FEED_MEDIATOR_IMPORTS_DIRECTORY=imports/prom
FEED_MEDIATOR_BUILDS_DIRECTORY=feeds/builds
FEED_MEDIATOR_PUBLISHED_DIRECTORY=feeds/published
FEED_MEDIATOR_FEEDBACK_DIRECTORY=imports/feedback
FEED_MEDIATOR_RUNBOOKS_DIRECTORY=feeds/runbooks
FEED_MEDIATOR_BACKUPS_DB_DIRECTORY=ops/backups/db
FEED_MEDIATOR_BACKUPS_FILES_DIRECTORY=ops/backups/files
FEED_MEDIATOR_PREFLIGHT_REQUIRE_REDIS=true
FEED_MEDIATOR_BACKUP_DB_AT=02:30
FEED_MEDIATOR_BACKUP_FILES_AT=03:00
FEED_MEDIATOR_PRUNE_AT=03:30
FEED_MEDIATOR_RET_GEN_DAYS=14
FEED_MEDIATOR_RET_PREVIEW_DAYS=7
FEED_MEDIATOR_RET_SMOKE_DAYS=30
FEED_MEDIATOR_RET_FEEDBACK_DAYS=30
FEED_MEDIATOR_RET_QA_BUNDLES_DAYS=14
FEED_MEDIATOR_RET_RUNBOOKS_DAYS=30
FEED_MEDIATOR_RET_OPS_RUNS_DAYS=45
FEED_MEDIATOR_BUILD_CHUNK_SIZE=250
FEED_MEDIATOR_XML_CHUNK_SIZE=250
FEED_MEDIATOR_WORKBENCH_PAGE_SIZE=20
FEED_MEDIATOR_RECON_BREAKDOWN_LIMIT=250
FEED_MEDIATOR_STORAGE_WARN_BYTES=2147483648
FEED_MEDIATOR_SEC_HEADERS_ENABLED=true
FEED_MEDIATOR_X_FRAME_OPTIONS=DENY
FEED_MEDIATOR_X_CONTENT_TYPE_OPTIONS=nosniff
FEED_MEDIATOR_REFERRER_POLICY=strict-origin-when-cross-origin
FEED_MEDIATOR_CONTENT_SECURITY_POLICY="default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; form-action 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'"
FEED_MEDIATOR_ADMIN_LOGIN_PER_MINUTE=5
FEED_MEDIATOR_ADMIN_SENSITIVE_PER_MINUTE=20
FEED_MEDIATOR_REQUIRE_HIGH_RISK_CONFIRMATION=false
FEED_MEDIATOR_DEPLOY_HEALTH_URL=/health
FEED_MEDIATOR_DEPLOY_SMOKE_FEED_PROFILE_ID=
FEED_MEDIATOR_REHEARSAL_PREVIEW_TTL_MINUTES=240
FEED_MEDIATOR_REHEARSAL_ALLOW_ON_PRODUCTION=false
FEED_MEDIATOR_SLO_HEALTHY_RATE=0.98
FEED_MEDIATOR_SLO_WARNING_RATE=0.90
FEED_MEDIATOR_STAGING_PUBLISH_NOTE="Staging publish is isolated from the production merchant feed URL."
FEED_MEDIATOR_NOTIFY_DB_ENABLED=true
FEED_MEDIATOR_NOTIFY_LOG_ENABLED=true
FEED_MEDIATOR_NOTIFY_MAIL_ENABLED=false
FEED_MEDIATOR_NOTIFY_MAIL_TO=
FEED_MEDIATOR_NOTIFY_LOG_CHANNEL=stack
FEED_MEDIATOR_NOTIFY_SUPPRESS_MINUTES=15
FEED_MEDIATOR_NOTIFY_REPEAT_MINUTES=30
FEED_MEDIATOR_NOTIFY_ESCALATE_MINUTES=15
FEED_MEDIATOR_NOTIFY_QUIET_TZ=Europe/Kyiv
FEED_MEDIATOR_NOTIFY_WEBHOOK_TIMEOUT=5
FEED_MEDIATOR_NOTIFY_WEBHOOK_RETRIES=3
FEED_MEDIATOR_NOTIFY_WEBHOOK_BACKOFF=60,300,900
FEED_MEDIATOR_NOTIFY_RET_DAYS=30
FEED_MEDIATOR_CORRELATION_HEADER=X-Correlation-ID
FEED_MEDIATOR_REDACT_KEYS=authorization,token,secret,password,api_key,api_token,webhook_url
FEED_MEDIATOR_ERROR_TRACKING_DRIVER=sentry
FEED_MEDIATOR_ERROR_TRACKING_DSN=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
