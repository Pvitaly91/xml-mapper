APP_NAME="xml-mapper.loc"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://xml-mapper.loc
APP_TIMEZONE=Europe/Kyiv

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12


LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xml_mapper_loc
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=900

FEED_MEDIATOR_QUEUE_IMPORTS=imports
FEED_MEDIATOR_QUEUE_NORMALIZATION=normalization
FEED_MEDIATOR_QUEUE_FEEDS=feeds
FEED_MEDIATOR_QUEUE_DICTIONARIES=dictionaries

FEED_MEDIATOR_LOCK_PREFIX=feed-mediator
FEED_MEDIATOR_DISPATCH_LOCK_TTL_SECONDS=1800
FEED_MEDIATOR_SOURCE_SYNC_LOCK_TTL_SECONDS=1800
FEED_MEDIATOR_FEED_BUILD_LOCK_TTL_SECONDS=1800
FEED_MEDIATOR_FEED_PUBLISH_LOCK_TTL_SECONDS=900
FEED_MEDIATOR_DICTIONARY_IMPORT_LOCK_TTL_SECONDS=1800

FEED_MEDIATOR_HEARTBEAT_STALE_AFTER_SECONDS=180
FEED_MEDIATOR_FAILED_JOBS_DEGRADED_THRESHOLD=1
FEED_MEDIATOR_KASTA_DICTIONARY_SAMPLE_PATH=
FEED_MEDIATOR_KASTA_DICTIONARY_STORAGE_DIRECTORY=imports/dictionaries

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
